{
  "name": "facebook-ads-view",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "YinoCloud Facebook ads data sync CLI.",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "fb-ads": "./src/cli.js"
  },
  "scripts": {
    "pull": "node --disable-warning=ExperimentalWarning src/cli.js pull",
    "active-ads": "node --disable-warning=ExperimentalWarning src/cli.js active-ads",
    "active-ads-hourly": "node --disable-warning=ExperimentalWarning src/cli.js active-ads-hourly",
    "active-campaigns": "node --disable-warning=ExperimentalWarning src/cli.js active-campaigns",
    "targeted-monitor": "node --disable-warning=ExperimentalWarning src/cli.js targeted-monitor",
    "sampling-config": "node --disable-warning=ExperimentalWarning src/cli.js sampling-config",
    "sampling-evaluate": "node --disable-warning=ExperimentalWarning src/cli.js sampling-evaluate",
    "sampling-run": "node --disable-warning=ExperimentalWarning src/cli.js sampling-run",
    "sampling-loop": "node --disable-warning=ExperimentalWarning src/cli.js sampling-loop",
    "db-init": "node --disable-warning=ExperimentalWarning src/cli.js db-init",
    "db-import-output": "node --disable-warning=ExperimentalWarning src/cli.js db-import-output",
    "accounts": "node --disable-warning=ExperimentalWarning src/cli.js accounts",
    "resource-list": "node --disable-warning=ExperimentalWarning src/cli.js resource-list",
    "ad-insights": "node --disable-warning=ExperimentalWarning src/cli.js ad-insights",
    "campaign-insights": "node --disable-warning=ExperimentalWarning src/cli.js campaign-insights",
    "monitor-bootstrap": "node --disable-warning=ExperimentalWarning src/cli.js monitor-bootstrap",
    "monitor-run": "node --disable-warning=ExperimentalWarning src/cli.js monitor-run",
    "monitor-loop": "node --disable-warning=ExperimentalWarning src/cli.js monitor-loop",
    "token": "node --disable-warning=ExperimentalWarning src/cli.js token",
    "doctor": "node --disable-warning=ExperimentalWarning src/cli.js doctor"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "dotenv": "^17.2.3",
    "p-limit": "^7.2.0"
  },
  "devDependencies": {}
}
