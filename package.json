{
  "name": "fb-ads-dashboard",
  "version": "0.1.0",
  "private": true,
  "description": "Facebook 广告数据看板独立模块",
  "scripts": {
    "start": "node --disable-warning=ExperimentalWarning src/server.js",
    "dev": "node --disable-warning=ExperimentalWarning src/server.js",
    "sentinel:start": "node ops/sentinel.js",
    "sentinel:check": "node ops/sentinel.js --check-config",
    "auth:create-admin": "node scripts/create-admin.js",
    "auth:reset-admin-password": "node scripts/create-admin.js --reset-password",
    "service:install": "powershell -NoProfile -ExecutionPolicy Bypass -File ops/install-windows-service.ps1 -Start",
    "service:uninstall": "powershell -NoProfile -ExecutionPolicy Bypass -File ops/uninstall-windows-service.ps1",
    "cli:install": "npm --prefix cli install",
    "cli:doctor": "npm --prefix cli run doctor",
    "cli:token": "npm --prefix cli run token",
    "cli:accounts": "npm --prefix cli run accounts --",
    "cli:resource-list": "npm --prefix cli run resource-list --",
    "cli:ad-insights": "npm --prefix cli run ad-insights --",
    "cli:campaign-insights": "npm --prefix cli run campaign-insights --",
    "cli:monitor-bootstrap": "npm --prefix cli run monitor-bootstrap --",
    "cli:monitor-run": "npm --prefix cli run monitor-run --",
    "cli:queue-run": "npm --prefix cli run queue-run --",
    "cli:monitor-loop": "npm --prefix cli run monitor-loop --",
    "cli:pull": "npm --prefix cli run pull --",
    "cli:active-ads": "npm --prefix cli run active-ads --",
    "cli:active-ads-hourly": "npm --prefix cli run active-ads-hourly --",
    "cli:active-campaigns": "npm --prefix cli run active-campaigns --",
    "cli:targeted-monitor": "npm --prefix cli run targeted-monitor --",
    "cli:sampling-config": "npm --prefix cli run sampling-config --",
    "cli:sampling-evaluate": "npm --prefix cli run sampling-evaluate --",
    "cli:sampling-run": "npm --prefix cli run sampling-run --",
    "cli:sampling-loop": "npm --prefix cli run sampling-loop --",
    "cli:db-init": "npm --prefix cli run db-init",
    "cli:db-import-output": "npm --prefix cli run db-import-output --"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "echarts": "^6.0.0",
    "tom-select": "^2.6.1"
  }
}
